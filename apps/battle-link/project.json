{
  "name": "battle-link",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "root": "apps/battle-link",
  "sourceRoot": "apps/battle-link/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ng build battle-link --configuration=production"
      },
      "configurations": {
        "production": {
          "command": "ng build battle-link --configuration=production"
        },
        "development": {
          "command": "ng build battle-link --configuration=development"
        },
        "local": {
          "command": "ng build battle-link --configuration=local"
        }
      },
      "defaultConfiguration": "production",
      "cache": true,
      "inputs": ["production", "sharedGlobals"],
      "outputs": ["{workspaceRoot}/dist/apps/battle-link"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ng serve battle-link --configuration=development"
      },
      "configurations": {
        "production": {
          "command": "ng serve battle-link --configuration=production"
        },
        "development": {
          "command": "ng serve battle-link --configuration=development"
        },
        "local": {
          "command": "ng serve battle-link --configuration=local"
        }
      },
      "defaultConfiguration": "development"
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ng test battle-link"
      },
      "cache": true,
      "inputs": ["default", "sharedGlobals"]
    }
  }
}
