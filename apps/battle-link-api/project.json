{
  "name": "battle-link-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "root": "apps/battle-link-api",
  "sourceRoot": "apps/battle-link-api/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nest build",
        "cwd": "apps/battle-link-api"
      },
      "cache": true,
      "inputs": ["production", "sharedGlobals"],
      "outputs": ["{workspaceRoot}/apps/battle-link-api/dist"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nest start --watch",
        "cwd": "apps/battle-link-api"
      },
      "configurations": {
        "local": {
          "command": "cross-env ENV_FILE=.env.local nest start --watch"
        },
        "development": {
          "command": "nest start --watch"
        }
      },
      "defaultConfiguration": "development"
    }
  }
}
